# GPS Tracking System Backend
# Environment variables

# MongoDB Configuration
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Ingestion Security
INGEST_API_KEY=hackathon-key

# GeoServer Integration
GEOSERVER_WFS_URL=
GEOSERVER_WMS_URL=
GEOSERVER_LAYER_NAMES=

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Redis Configuration (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Alert Thresholds
SPEED_VIOLATION_THRESHOLD=120
STATIONARY_TIME_THRESHOLD=300
STATIONARY_DISTANCE_THRESHOLD=0.01

# Notification Providers
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_RECIPIENT=

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_TO=
